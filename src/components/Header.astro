---
import ThemeToggle from './ThemeToggle.astro';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'GreenLivingTrend';
const navItems = [
  { label: 'Journal', href: '/posts/' },
  { label: 'Energy Audit', href: '/energy-audit/' },
  { label: 'Categories', href: '/categories/' },
  { label: 'Search', href: '/search/' },
  { label: 'Standards', href: '/editorial-standards' },
];
---

<header class="sticky top-0 z-50 glass border-b">
  <div class="border-b border-border/45 bg-muted/35">
    <div class="site-shell flex min-h-8 items-center justify-between gap-3 text-[10px] font-mono uppercase tracking-[0.22em] text-muted-foreground">
      <span>Ecological Ledger</span>
      <span class="hidden sm:inline">Verified household sustainability data</span>
    </div>
  </div>
  <div class="site-shell flex min-h-[76px] items-center justify-between gap-4">
    <a href="/" class="group flex min-w-0 items-center gap-3" aria-label={`${siteName} home`}>
      <span class="inline-grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-primary text-primary-foreground" aria-hidden="true">
        <svg viewBox="0 0 44 44" class="h-8 w-8" fill="none">
          <path d="M25 7c-8 4-13 10-13 18 0 6 4 10 10 10 9 0 14-9 15-26-4 1-8 2-12 4Z" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/>
          <path d="M13 31c7-7 13-12 24-18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M11 35h24" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity=".65"/>
        </svg>
      </span>
      <span class="truncate text-2xl font-bold leading-none tracking-[-0.025em] md:text-3xl" style="font-family: var(--font-display);">{siteName}</span>
    </a>

    <div class="flex items-center gap-3 md:gap-5">
      <nav aria-label="Primary navigation" class="hidden lg:block">
        <ul class="flex items-center gap-1 text-xs uppercase tracking-[0.12em]">
          {navItems.map((item) => <li><a href={item.href} class="rounded-full px-3 py-2 text-foreground/75 transition-colors hover:bg-muted hover:text-primary">{item.label}</a></li>)}
        </ul>
      </nav>
      <a href="/energy-audit/" class="hidden md:inline-flex btn-secondary min-h-10 py-2">Audit Tool</a>
      <ThemeToggle />
    </div>
  </div>
  <nav aria-label="Mobile primary navigation" class="lg:hidden border-t border-border/55 bg-background/95">
    <ul class="site-shell flex gap-2 overflow-x-auto py-2 text-[11px] font-semibold uppercase tracking-[0.12em] [-webkit-overflow-scrolling:touch]">
      {navItems.map((item) => <li class="shrink-0"><a href={item.href} class="inline-flex min-h-10 items-center rounded-full border border-border/70 bg-card px-4 text-foreground/75">{item.label}</a></li>)}
    </ul>
  </nav>
</header>
