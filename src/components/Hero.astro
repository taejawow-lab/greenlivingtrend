---
export interface Props { title: string; subtitle: string; illustration?: string; ctaText?: string; ctaHref?: string; }
const envIllustration = import.meta.env.PUBLIC_HAS_HERO_ILLUSTRATION === 'true' ? '/images/illustrations/hero.png' : undefined;
const { title, subtitle, illustration = envIllustration, ctaText = 'Read latest', ctaHref = '#latest' } = Astro.props;
const dateline = new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).toUpperCase();
---

<section class="relative overflow-hidden bg-background">
  <div class="absolute inset-0 pointer-events-none opacity-[0.07]" aria-hidden="true" style="background-image: linear-gradient(to right, rgb(var(--color-primary)) 1px, transparent 1px), linear-gradient(to bottom, rgb(var(--color-primary)) 1px, transparent 1px); background-size: 72px 72px;"></div>
  <div class="absolute -right-32 top-10 h-[34rem] w-[34rem] rounded-full bg-primary/10 blur-3xl" aria-hidden="true"></div>
  <div class="absolute -left-28 bottom-0 h-[28rem] w-[28rem] rounded-full bg-accent/10 blur-3xl" aria-hidden="true"></div>

  <div class="site-shell relative pb-20 pt-12 md:pb-28 md:pt-16">
    <div class="mb-12 flex items-center gap-4 text-xs font-mono uppercase tracking-[0.18em] text-muted-foreground md:mb-20">
      <span>Issue № 01 · Household climate</span>
      <span class="h-px flex-1 bg-border"></span>
      <span>{dateline}</span>
    </div>

    <div class="grid grid-cols-12 gap-6 md:gap-8 md:items-start">
      <div class="relative z-10 col-span-12 md:col-span-8">
        <p class="mb-5 text-xs font-mono uppercase tracking-[0.2em] text-accent">Verified data · low-waste decisions</p>
        <h1 class="max-w-5xl text-balance text-5xl font-bold leading-[1.03] tracking-[-0.025em] md:text-7xl lg:text-[6.7rem]" style="font-family: var(--font-display);">{title}</h1>
        <p class="mt-8 max-w-2xl text-pretty text-lg leading-8 text-foreground/75 md:text-2xl md:leading-9">{subtitle}</p>
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a href={ctaHref} class="btn-primary">{ctaText} →</a>
          <a href="/energy-audit/" class="btn-secondary">Open energy audit</a>
        </div>
      </div>

      <aside class="col-span-12 md:col-span-4 md:-ml-8 md:mt-10">
        <div class="ledger-card p-4 md:p-5">
          {illustration ? <img src={illustration} alt="" class="aspect-[4/5] w-full rounded-2xl object-cover" loading="eager" /> : (
            <div class="aspect-[4/5] rounded-2xl bg-muted p-6">
              <svg viewBox="0 0 320 400" class="h-full w-full" fill="none" aria-hidden="true">
                <path d="M185 40C100 83 54 146 61 222c5 58 45 95 101 91 86-7 128-94 134-249-39 10-77 19-111 35Z" fill="rgb(var(--color-primary) / .14)" stroke="rgb(var(--color-primary))" stroke-width="3"/>
                <path d="M71 292c65-75 123-128 210-189" stroke="rgb(var(--color-primary))" stroke-width="4" stroke-linecap="round"/>
                <path d="M58 342h210" stroke="rgb(var(--color-accent))" stroke-width="3" stroke-linecap="round"/>
              </svg>
            </div>
          )}
          <p class="mt-4 text-[10px] font-mono uppercase tracking-[0.2em] text-muted-foreground">↑ Ecological ledger cover system</p>
        </div>
      </aside>
    </div>

    <div class="mt-16 grid gap-4 border-t border-border pt-6 md:grid-cols-4">
      <div class="data-readout"><span class="value">EPA</span><span class="label">source layer</span></div>
      <div class="data-readout"><span class="value">DOE</span><span class="label">energy math</span></div>
      <div class="data-readout"><span class="value">ROI</span><span class="label">household savings</span></div>
      <div class="data-readout"><span class="value">CO₂</span><span class="label">impact estimate</span></div>
    </div>
  </div>
</section>
