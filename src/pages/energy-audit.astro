---
import BaseLayout from '../layouts/BaseLayout.astro';
const improvements = [
  ['Air sealing + weatherstripping', '$210/yr', '0.42 tons', 'High'],
  ['Smart thermostat schedule', '$140/yr', '0.28 tons', 'Medium'],
  ['Window shade + cross ventilation', '$95/yr', '0.18 tons', 'Medium'],
  ['Cold-water laundry routine', '$52/yr', '0.10 tons', 'Low'],
];
---

<BaseLayout title="Home Energy Audit Tool" description="A GreenLivingTrend Ecological Ledger dashboard for home efficiency, ROI, and carbon-reduction priorities.">
  <section class="site-shell py-14 md:py-20">
    <span class="eco-chip">Interactive concept · Home Energy Audit</span>
    <h1 class="mt-6 max-w-4xl text-balance text-5xl font-bold leading-tight md:text-7xl">Rank home upgrades by savings, comfort, and CO₂ reduction.</h1>
    <p class="mt-6 max-w-2xl text-lg leading-8 text-muted-foreground">This dashboard is a public-facing tool surface from the renewal handoff. It avoids overpromising exact utility savings and frames results as planning estimates.</p>

    <div class="mt-10 grid gap-6 lg:grid-cols-[.9fr_.75fr_1.1fr]">
      <form class="ledger-card space-y-5">
        <h2 class="mt-0 text-3xl">Foundation data</h2>
        <label class="block"><span class="text-xs font-bold uppercase tracking-[0.16em] text-muted-foreground">Home size</span><input value="1,650 sq ft" class="mt-2 w-full rounded-xl border border-border bg-background px-4 py-3" /></label>
        <label class="block"><span class="text-xs font-bold uppercase tracking-[0.16em] text-muted-foreground">HVAC type</span><select class="mt-2 w-full rounded-xl border border-border bg-background px-4 py-3"><option>Heat pump</option><option>Gas furnace + AC</option><option>Portable AC</option></select></label>
        <label class="block"><span class="text-xs font-bold uppercase tracking-[0.16em] text-muted-foreground">System age</span><select class="mt-2 w-full rounded-xl border border-border bg-background px-4 py-3"><option>8–12 years</option><option>0–7 years</option><option>13+ years</option></select></label>
        <p class="text-sm text-muted-foreground">Inputs are local demo fields for planning. Verify utility rebates, installation safety, and local codes before spending.</p>
      </form>

      <div class="ledger-card grid place-items-center text-center">
        <div class="audit-gauge"><span>72</span></div>
        <h2 class="mt-6 text-3xl">Efficiency Index</h2>
        <p class="mt-3 text-sm leading-6 text-muted-foreground">Moderate upgrade potential. Start with low-cost envelope and thermostat changes before appliance replacement.</p>
      </div>

      <div class="ledger-card">
        <h2 class="mt-0 text-3xl">High-impact improvements</h2>
        <div class="mt-6 divide-y divide-border">
          {improvements.map(([name, savings, co2, effort], i) => (
            <div class="grid gap-3 py-4 sm:grid-cols-[44px_1fr_auto] sm:items-center">
              <span class="font-mono text-sm text-muted-foreground">№ {String(i+1).padStart(2,'0')}</span>
              <div><h3 class="mt-0 text-xl">{name}</h3><p class="text-sm text-muted-foreground">Estimated: {savings} · {co2} CO₂e · Effort {effort}</p></div>
              <span class="verified-leaf">ROI</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
