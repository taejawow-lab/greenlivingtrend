---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ArticleCard from '../components/ArticleCard.astro';
const posts = (await getCollection('posts')).filter((p)=>!p.data.draft).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
const featuredPosts = posts.slice(0,3);
const recentPosts = posts.slice(3,12);
const siteDescription = import.meta.env.PUBLIC_SITE_DESCRIPTION || 'Verified household sustainability, energy, water, and low-waste guides.';
const heroTitle = import.meta.env.PUBLIC_SITE_HERO_TITLE || 'Practical Sustainability, Verified at Home';
const heroSubtitle = import.meta.env.PUBLIC_SITE_HERO_SUBTITLE || siteDescription;
---

<BaseLayout title="Ecological Ledger Home" description={siteDescription}>
  <Hero title={heroTitle} subtitle={heroSubtitle} ctaText="Read latest" ctaHref="#latest" />

  <section class="site-shell py-16 md:py-24">
    <div class="grid gap-8 lg:grid-cols-[.95fr_1.05fr]">
      <div class="ledger-card">
        <span class="eco-chip">Home Energy Audit Tool</span>
        <h2 class="mt-5 max-w-xl">Efficiency decisions ranked by savings, comfort, and CO₂ impact.</h2>
        <p class="mt-4 text-muted-foreground">The redesign adds a visible tool surface for square footage, HVAC age, an Efficiency Index gauge, and ranked improvements.</p>
        <a href="/energy-audit/" class="btn-primary mt-8">Open audit tool</a>
      </div>
      <div class="ledger-card grid gap-5 md:grid-cols-[180px_1fr] md:items-center">
        <div class="audit-gauge"><span>72</span></div>
        <div class="space-y-4">
          <div><div class="mb-2 flex justify-between text-xs font-bold uppercase tracking-[0.14em] text-muted-foreground"><span>Air sealing priority</span><span>$210/yr</span></div><div class="h-2 rounded-full bg-muted"><div class="h-2 w-[82%] rounded-full bg-primary"></div></div></div>
          <div><div class="mb-2 flex justify-between text-xs font-bold uppercase tracking-[0.14em] text-muted-foreground"><span>Smart thermostat setup</span><span>$140/yr</span></div><div class="h-2 rounded-full bg-muted"><div class="h-2 w-[64%] rounded-full bg-[color:var(--sage)]"></div></div></div>
          <div><div class="mb-2 flex justify-between text-xs font-bold uppercase tracking-[0.14em] text-muted-foreground"><span>Window shade plan</span><span>$95/yr</span></div><div class="h-2 rounded-full bg-muted"><div class="h-2 w-[44%] rounded-full bg-accent"></div></div></div>
        </div>
      </div>
    </div>
  </section>

  {featuredPosts.length > 0 && (
    <section id="latest" class="site-shell py-16 md:py-24">
      <div class="mb-12 grid grid-cols-12 gap-6 border-b border-border pb-10">
        <div class="col-span-12 md:col-span-4"><p class="mb-3 font-mono text-[10px] uppercase tracking-[0.25em] text-accent">¶ Section 01</p><h2 class="text-5xl md:text-7xl">Lead Stories</h2></div>
        <div class="col-span-12 md:col-span-7 md:col-start-6 md:pt-4"><p class="max-w-xl text-lg leading-8 text-foreground/70">Primary-source household sustainability guidance: energy, water, air quality, and low-waste routines without lifestyle theater.</p><a href="/posts/" class="btn-secondary mt-5">View archive</a></div>
      </div>
      <div class="grid grid-cols-12 gap-6 md:gap-8">
        {featuredPosts[0] && <div class="col-span-12 md:col-span-7"><ArticleCard title={featuredPosts[0].data.title} description={featuredPosts[0].data.description} href={`/posts/${featuredPosts[0].slug}`} image={featuredPosts[0].data.heroImage} category={featuredPosts[0].data.category} pubDate={featuredPosts[0].data.pubDate} variant="feature" index={0}/></div>}
        {featuredPosts.slice(1).map((post,i)=><div class="col-span-12 md:col-span-5"><ArticleCard title={post.data.title} description={post.data.description} href={`/posts/${post.slug}`} image={post.data.heroImage} category={post.data.category} pubDate={post.data.pubDate} variant="standard" index={i+1}/></div>)}
      </div>
    </section>
  )}

  {recentPosts.length > 0 && (
    <section class="border-t border-border py-16 md:py-24">
      <div class="site-shell">
        <div class="mb-10 flex flex-col gap-3 md:flex-row md:items-end md:justify-between"><div><p class="mb-3 font-mono text-[10px] uppercase tracking-[0.25em] text-accent">¶ Section 02</p><h2>Recent ledger entries</h2></div><p class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground">↓ {recentPosts.length} stories · Sorted by date</p></div>
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {recentPosts.map((post,i)=><ArticleCard title={post.data.title} description={post.data.description} href={`/posts/${post.slug}`} image={post.data.heroImage} category={post.data.category} pubDate={post.data.pubDate} variant="standard" index={i+3}/>) }
        </div>
      </div>
    </section>
  )}
</BaseLayout>
